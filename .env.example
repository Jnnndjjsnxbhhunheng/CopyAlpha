# SocialData API (required)
# Get your key at https://socialdata.tools
SOCIALDATA_API_KEY=your-api-key

# LLM mode (optional)
# - openclaw: use OpenClaw Gateway
# - openai-compatible: use any OpenAI-compatible /v1 backend
LLM_PROVIDER=openclaw
LLM_MODEL=openclaw
LLM_TIMEOUT_MS=120000
LLM_MAX_RETRIES=4
LLM_RETRY_BASE_DELAY_MS=1500
LLM_RETRY_MAX_DELAY_MS=15000

# OpenClaw Gateway (recommended default)
OPENCLAW_GATEWAY_BASE_URL=http://127.0.0.1:18789/v1
OPENCLAW_AGENT_ID=main
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PASSWORD=

# Generic OpenAI-compatible backend (optional override)
LLM_BASE_URL=
LLM_API_KEY=

# OKX OnchainOS (optional, for on-chain queries)
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Harvest Config
HARVEST_INTERVAL_SECONDS=60
HARVEST_HISTORY_DEPTH=500
HARVEST_MAX_CONCURRENT=3
