# Twitter Data Source
TWITTER_BEARER_TOKEN=your-bearer-token
NITTER_INSTANCES=https://nitter.privacydev.net,https://nitter.poast.org

# LLM Backend (OpenClaw-first)
LLM_PROVIDER=openclaw
LLM_MODEL=openclaw
OPENCLAW_GATEWAY_BASE_URL=http://127.0.0.1:18789/v1
OPENCLAW_AGENT_ID=main
# Optional if your OpenClaw gateway requires auth
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PASSWORD=
# If OpenClaw already manages provider keys and gateway auth is disabled, leave these blank.

# Optional generic OpenAI-compatible override
LLM_BASE_URL=
LLM_API_KEY=
LLM_TIMEOUT_MS=120000

# OKX OnchainOS
OKX_API_KEY=your-key
OKX_SECRET_KEY=your-secret
OKX_PASSPHRASE=your-passphrase
WALLET_ADDRESS=your-wallet-address

# Harvest Config
HARVEST_INTERVAL_SECONDS=60
HARVEST_HISTORY_DEPTH=500
HARVEST_MAX_CONCURRENT=3
